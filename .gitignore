# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

node_modules
**/node_modules
**/*/node_modules

.idea
.idea/*
.idea/**

.env
*/.env
**/.env

octadground.js
*/octadground.js
**/octadground.js

yarn-error.log
*/yarn-error.log
**/yarn-error.log

.DS_Store
*/.DS_Store
**/.DS_Store
# Tailwind standalone CLI binary (downloaded, ~80MB; not committed)
bin/tailwindcss

# docker-compose secret files (see docker-compose.yaml)
deploy/secrets/

# Generated frontend assets — not committed. Fetched from pinned sources and
# (re)built inside the Docker image at deploy time (see src/Dockerfile), or by
# bin/build-assets.sh for local dev. Embedded via //go:embed static/* in cmd/lio.
# (octadground.js is already matched by the octadground.js rules above.)
src/cmd/lio/static/app.css
src/cmd/lio/static/themes.css
src/cmd/lio/static/octadground.base.css

# Redis database
!/dump.rdb
*.rdb