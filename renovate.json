{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump the pinned OCTADGROUND_REF / TAILWIND_VERSION ARGs in the Dockerfile",
      "fileMatch": [
        "(^|/)Dockerfile$"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)[^\\n]*\\n\\s*ARG\\s+\\w+=\"?(?<currentValue>[^\"\\s]+)\"?"
      ]
    }
  ]
}
