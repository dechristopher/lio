# Local dev config for `go run ./cmd/lio` (godotenv loads .env from the working
# dir). Copy this file to .env (gitignored) and fill DEV_CRYPTO_KEY. Bring the
# backing services up with `dev/dev.sh up`; `dev/dev.sh env` prints a ready block.
DEPLOY=local
PORT=4444

# 16/24/32-byte string for session/identity crypto (AES). Generate with
# `dev/dev.sh env` or `openssl rand -base64 24`. Blank ⇒ "invalid key size 0".
DEV_CRYPTO_KEY=

# Room restart persistence (redis). Unset ⇒ persistence disabled locally.
DEV_LIO_REDIS_ADDR=localhost:6379

# Durable relational game archive (postgres). Unset ⇒ archive disabled locally.
DEV_LIO_PG_DSN=postgres://lio:lio@localhost:5432/lio?sslmode=disable

# Optional background position evaluator (fills the deduped positions eval
# cache). Set to 1 to enable; off by default.
DEV_LIO_PG_EVALUATOR=

# Optional object store for PGN archival (dev/dev.sh minio). Leave ENDPOINT
# empty to disable archival — store.Up uses TLS (Secure:true), so local
# plain-http MinIO won't connect without a code/TLS change, and empty is the
# normal local setting (the Postgres archive is unaffected).
DEV_LIO_OBJ_ENDPOINT=
DEV_LIO_OBJ_ACCESS=lioadmin
DEV_LIO_OBJ_SECRET=liosecret123
DEV_LIO_OBJ_BUCKET_PGN=lio-pgn
